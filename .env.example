PORT=8080
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match the callback URI registered in your GitHub OAuth App settings
GITHUB_REDIRECT_URI=https://hng14-stage1-backend.vercel.app/auth/github/callback

# JWT: minimum 32 character random secret (use: openssl rand -hex 32)
JWT_SECRET=

# Web portal origin — used for CORS with credentials (browser cookie flow)
FRONTEND_URL=https://your-web-portal.vercel.app

# External API base URLs
GENDERIZE_BASE_URL=https://api.genderize.io
AGIFY_BASE_URL=https://api.agify.io
NATIONALIZE_BASE_URL=https://api.nationalize.io

HTTP_TIMEOUT_SECONDS=5
